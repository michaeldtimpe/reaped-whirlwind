# reaped-whirlwind environment — copy to .env and fill in.  .env is GITIGNORED.
# This file is the canonical list of every variable the stack reads.

# Timezone + Synology user/group (for file ownership on the NAS)
TZ=America/Chicago
PUID=106808
PGID=106808

# Radar image processor
PROCESSING_MODE=normal
SAMPLE_RATE=4

# Weather reporter (NWS API). NWS REQUIRES a real contact in the User-Agent.
NWS_REGION=DFW
NWS_LAT=32.8968
NWS_LON=-97.0380
NWS_UA=(reaped-whirlwind weather-reporter, you@example.com)
WEATHER_INTERVAL=600

# Email / SMTP alerting (Part C). The alerting layer sends NWS + experimental-model alerts.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=changeme
ALERT_FROM=you@example.com
ALERT_TO=you@example.com

# Model inference (Part C)
# Annotation threshold (NOT a safety threshold). Lowering it just makes the
# "elevated" annotation easier to reach; it does not affect whether an email
# is sent (NWS warning gates that). See docs/MODEL_CARD.md "Tuning" for the
# precision/recall trade-off and the 0.5 alternative.
MODEL_RISK_THRESHOLD=0.8

# Inference cycle cadence (seconds). 300 matches IEM RIDGE's typical N0B
# refresh; the alerting service polls at the same cadence by default.
INFERENCE_POLL_INTERVAL=300
ALERTING_POLL_INTERVAL=300

# N0B/N0S temporal-pairing window (seconds). If no N0S is available within
# this many seconds of the latest N0B, the inference cycle skips scoring
# (does NOT substitute a stale velocity scan).
MAX_PAIR_DELTA_SECONDS=300

# A model score this old is treated as "unavailable" by the alerting service
# (and surfaced as "stale" by /health). 1800s = 30 min.
MAX_SCORE_AGE_SECONDS=1800

# KFWS WSR-88D coordinates (used by both inference for cropping and alerting
# for the NWS /alerts/active?point=... query).
KFWS_LAT=32.5728
KFWS_LON=-97.3031

# Optional: SHA256 of models/v1/model.pt. If set, the inference service
# refuses to start unless model.pt matches. Falls back to manifest.json.
# MODEL_FINGERPRINT=
