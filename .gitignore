# Secrets / runtime config
.env

# Python
__pycache__/
*.pyc
*.pyo
.venv*/
venv/
*.egg-info/
.ipynb_checkpoints/

# OS / editor
.DS_Store
*.zip

# Radar imagery / training data only ever lives under data/ (ignored above). The only
# images intentionally tracked are services/processor/base_*_intensity_scale.png
# (small color-scale references the processor needs to decode radar -> JSON).
*.tif
*.tiff

# Data — bind-mounted from /volume1/docker/... on the NAS, NEVER committed.
# (The compose file documents the host paths; the data itself stays out of git.)
weather-screenshots/
processed-weather-screenshots/
weather-reports/
service-status/
radar-image-processor-logs/
postive-tornado-images-*/
tornado_dataset/
data/
*.log
logs/

# ML artifacts (weights, exports, large run outputs).
# Training-run weights and intermediate artifacts stay out (multi-MB, many runs).
# We *do* track canonical deployed models under models/<version>/model.pt — the
# deploy pattern (git archive HEAD | ssh) requires them to be tracked, the file
# is small (~400 KB), and tracking them makes a model swap reviewable in git.
*.pt
*.pth
*.onnx
*.npy
*.npz
!models/**/model.pt
ml/runs/
